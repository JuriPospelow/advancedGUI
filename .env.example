# HTTP server port
PORT=8080

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Directory where Unix socket device files are placed and scanned
UNIX_SOCKET_DIR=/tmp/sockets

# Path to the authentication JSON file (user accounts)
AUTH_FILE=/.auth.json

# MQTT broker port (0 = dynamic / random; set to a fixed port like 1883
# when external devices such as ESP32 need to connect to the broker)
MQTT_BROKER_PORT=1883
